      {
        "type": "assertion",
        "description": "Verify URL contains \"/book\""
      },
      {
        "type": "action",
        "description": "Fill \"Patient Name\" with \"Test Patient\""
      },
      {
        "type": "action",
        "description": "Fill \"Age\" with \"35\""
      },
      {
        "type": "action",
