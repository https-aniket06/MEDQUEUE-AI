    "priority": "High",
    "steps": [
      {
        "type": "action",
        "description": "Navigate to /"
      },
      {
        "type": "assertion",
        "description": "Verify element \"Emergency Help\" is visible"
      },
      {
        "type": "action",
        "description": "Click on \"Emergency Help\""
      },
      {
        "type": "assertion",
        "description": "Verify text \"Ambulance\" is visible"
      },
      {
        "type": "assertion",
        "description": "Verify text \"Dispatched\" is visible"
      },
      {
        "type": "assertion",
        "description": "Verify text \"ETA\" is visible"
      },
      {
