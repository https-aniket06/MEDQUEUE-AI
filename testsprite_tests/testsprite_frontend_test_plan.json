    "id": "TC012",
    "title": "Run AI triage successfully with a typical symptom description",
    "description": "Verifies that entering symptoms and running the check displays a triage care level and guidance.",
    "category": "AI Symptom Checker (Neural Triage)",
    "priority": "High",
    "steps": [
      {
        "type": "action",
        "description": "Navigate to /symptoms"
      },
      {
        "type": "assertion",
        "description": "Verify text \"AI Neural Triage System\" is visible"
      },
      {
        "type": "action",
        "description": "Type \"I have a fever and sore throat for 2 days\" into the symptoms input field"
      },
      {
        "type": "action",
        "description": "Click on the \"Run Check\" button"
      },
      {
        "type": "assertion",
        "description": "Verify text \"Recommended\" is visible"
      },
      {
        "type": "assertion",
        "description": "Verify text \"Guidance\" is visible"
      }
    ]
  },
