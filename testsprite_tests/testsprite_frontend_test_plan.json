  {
    "id": "TC007",
    "title": "Successful token booking for Cardiology at General Hospital shows confirmation and token number",
    "description": "Verifies end-to-end booking from hospital selection through booking confirmation including token number visibility.",
    "category": "Token Booking",
    "priority": "High",
    "steps": [
      {
        "type": "action",
        "description": "Navigate to /auth/patient"
      },
      {
        "type": "action",
        "description": "Type \"{{LOGIN_USER}}\" into the email field"
