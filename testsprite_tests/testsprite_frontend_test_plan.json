  {
    "id": "TC005",
    "title": "Patient can log in from patient auth page and land on Patient page",
    "description": "Verifies a patient can authenticate using email/password and reach the /patient page.",
    "category": "Token Booking",
    "priority": "High",
    "steps": [
      {
        "type": "action",
        "description": "Navigate to /auth/patient"
      },
      {
        "type": "action",
        "description": "Type \"{{LOGIN_USER}}\" into the email field"
      },
      {
        "type": "action",
        "description": "Type \"{{LOGIN_PASSWORD}}\" into the password field"
      },
      {
        "type": "action",
        "description": "Click the \"Login\" button"
      },
      {
        "type": "assertion",
        "description": "Verify URL contains \"/patient\""
      },
      {
        "type": "assertion",
        "description": "Verify text \"Search\" is visible"
      }
    ]
  },
