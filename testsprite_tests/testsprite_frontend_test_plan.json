      },
      {
        "type": "action",
        "description": "Click the \"Book Token\" button"
      },
      {
        "type": "assertion",
        "description": "Verify text \"Booking confirmed\" is visible"
      },
      {
        "type": "assertion",
        "description": "Verify text \"Token\" is visible"
      }
    ]
  },
